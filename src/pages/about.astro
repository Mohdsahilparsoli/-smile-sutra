---
import AboutHeroImage from "../assets/blog-placeholder-about.jpg";
import Layout from "../layouts/BlogPost.astro";
---

<Layout
  title="About Smile Sutra Dental Clinic | Trusted Dentists in Delhi NCR"
  description="Learn about Smile Sutra Dental Clinic, providing trusted dental care in Delhi, Noida, Gurgaon, and Ghaziabad. Meet our experienced team dedicated to advanced, comfortable, and affordable dentistry."
  pubDate={new Date("August 08 2021")}
  heroImage={AboutHeroImage}
>
  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero" id="top">
    <div class="container page-hero-inner reveal in-view">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>About Us</span>
      </div>

      <div class="eyebrow">Delhi · Noida · Gurgaon · Ghaziabad</div>

      <h1>
        A decade of <span>trusted dental care</span>, built around Delhi NCR
        families
      </h1>

      <p>
        Smile Sutra was founded on a simple idea: dentistry should be gentle,
        transparent, and genuinely convenient for the people who rely on it
        every day. Here's the story behind the clinic and the team caring for
        your smile.
      </p>
    </div>

    <div class="curve-divider">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none">
        <path
          d="M0,32 C240,64 480,0 720,20 C960,40 1200,64 1440,24 L1440,60 L0,60 Z"
          fill="#FFFFFF"></path>
      </svg>
    </div>
  </section>

  <!-- ===== OUR STORY ===== -->
  <section id="story">
    <div class="container about-grid">
      <div class="about-visual reveal">
        <div
          class="eyebrow"
          style="background:rgba(255,255,255,0.15); color:#fff;"
        >
          Serving all of NCR
        </div>

        <h3>One clinic, every corner of the capital covered</h3>

        <p>
          What started as a single chair in Laxmi Nagar has grown into a trusted
          name across the National Capital Region &mdash; serving patients from
          South Delhi to Sector 62 Noida, DLF Gurgaon, and Vaishali Ghaziabad.
        </p>

        <div class="location-tags">
          <span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"
              ></path>
            </svg>
            Delhi
          </span>
          <span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"
              ></path>
            </svg>
            Noida
          </span>
          <span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"
              ></path>
            </svg>
            Gurgaon
          </span>
          <span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"
              ></path>
            </svg>
            Ghaziabad
          </span>
        </div>

        <div class="about-stats">
          <div class="about-stat">
            <b>10+</b>
            <span>Years serving NCR families</span>
          </div>
          <div class="about-stat">
            <b>5000+</b>
            <span>Happy patients treated</span>
          </div>
          <div class="about-stat">
            <b>15+</b>
            <span>Dental procedures offered</span>
          </div>
          <div class="about-stat">
            <b>7 Days</b>
            <span>Open, incl. Sundays</span>
          </div>
        </div>
      </div>

      <div class="about-body reveal reveal-delay-1">
        <div class="eyebrow">Our Story</div>

        <h2>Modern dentistry, rooted in trust for Delhi NCR families</h2>

        <p>
          Smile Sutra Dental &amp; Implant Clinic has been caring for smiles
          across Delhi NCR for over a decade. What began as a small practice
          focused on painless root canals has grown into a full-service clinic
          offering everything from routine cleanings to full-mouth implant
          rehabilitation &mdash; without ever losing sight of the personal,
          unhurried care patients came to us for in the first place.
        </p>

        <p>
          We believe good dental care shouldn't mean long waits or confusing
          bills. Every treatment plan and cost is explained upfront in simple
          terms, in Hindi or English, whichever you prefer, using a sterilised,
          hospital-grade setup and the latest digital X-ray technology.
        </p>

        <div class="about-points">
          <div class="about-point">
            <span class="about-point-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M20 7L9 18l-5-5"></path>
              </svg>
            </span>
            <div>
              <h4>International hygiene standards</h4>
              <p>
                Autoclave sterilisation and single-use disposables for every
                patient.
              </p>
            </div>
          </div>

          <div class="about-point">
            <span class="about-point-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                <path d="M2 10h20"></path>
              </svg>
            </span>
            <div>
              <h4>Transparent, fair pricing</h4>
              <p>
                Upfront INR quotes with easy EMI options &mdash; no hidden
                charges.
              </p>
            </div>
          </div>

          <div class="about-point">
            <span class="about-point-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 7v5l3 2"></path>
              </svg>
            </span>
            <div>
              <h4>Flexible NCR-friendly timings</h4>
              <p>
                Open 7 days a week, including evenings for working
                professionals.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MISSION / VISION / VALUES ===== -->
  <section class="section-alt" id="values">
    <div class="container">
      <div class="section-head reveal">
        <div class="eyebrow">What Drives Us</div>
        <h2>Our mission and the values behind every treatment</h2>
        <p>
          Three principles guide every decision we make, from how we design a
          treatment plan to how we greet you at the door.
        </p>
      </div>

      <div class="values-grid">
        <div class="value-card reveal">
          <div class="value-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21l7.78-7.55 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
              ></path>
            </svg>
          </div>
          <h3>Patient-first care</h3>
          <p>
            Every treatment plan starts with listening. We take the time to
            understand your concerns before recommending a single procedure.
          </p>
        </div>

        <div class="value-card reveal reveal-delay-1">
          <div class="value-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M12 2l9 5-9 5-9-5 9-5z"></path>
              <path d="M3 12l9 5 9-5"></path>
              <path d="M3 17l9 5 9-5"></path>
            </svg>
          </div>
          <h3>Clinical excellence</h3>
          <p>
            We invest in continuing education and modern equipment so every
            procedure meets the highest standard of clinical safety.
          </p>
        </div>

        <div class="value-card reveal reveal-delay-2">
          <div class="value-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="2" y="5" width="20" height="14" rx="2"></rect>
              <path d="M2 10h20"></path>
            </svg>
          </div>
          <h3>Complete transparency</h3>
          <p>
            No surprise bills. Every cost, alternative, and timeline is
            explained in plain language before we begin any treatment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR JOURNEY / TIMELINE ===== -->
  <section id="journey">
    <div class="container">
      <div class="section-head reveal">
        <div class="eyebrow">Our Journey</div>
        <h2>A decade of growth, one satisfied patient at a time</h2>
        <p>
          From a single clinic to a name trusted across four cities in the NCR.
        </p>
      </div>

      <div class="timeline">
        <div class="timeline-item reveal">
          <div class="timeline-dot">'14</div>
          <div class="timeline-content">
            <h4>Smile Sutra opens in Laxmi Nagar</h4>
            <p>
              Our first clinic opens its doors in East Delhi, focused on
              painless root canal treatment and general dentistry.
            </p>
          </div>
        </div>

        <div class="timeline-item reveal reveal-delay-1">
          <div class="timeline-dot">'17</div>
          <div class="timeline-content">
            <h4>Implantology and orthodontics added</h4>
            <p>
              Dr. Sri completes advanced certification in implantology,
              expanding our services to dental implants and braces.
            </p>
          </div>
        </div>

        <div class="timeline-item reveal reveal-delay-2">
          <div class="timeline-dot">'20</div>
          <div class="timeline-content">
            <h4>1,000th patient milestone</h4>
            <p>
              Word-of-mouth referrals across Delhi NCR help us cross our 1,000th
              treated patient, with a growing base of returning families.
            </p>
          </div>
        </div>

        <div class="timeline-item reveal reveal-delay-3">
          <div class="timeline-dot">'26</div>
          <div class="timeline-content">
            <h4>5,000+ patients across four NCR cities</h4>
            <p>
              Today, Smile Sutra serves patients from Delhi, Noida, Gurgaon, and
              Ghaziabad, with a 4.9-star rating from over 800 reviews.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SPECIALIST ===== -->
  <section class="section-alt" id="specialist">
    <div class="container">
      <div class="specialist">
        <div class="specialist-photo reveal">
          <div class="specialist-photo-frame">
            <div class="specialist-photo-inner">
              <img
                class="doctor-silhouette"
                src="assets/img/about.png"
                alt="Dr. Sri - Senior Dental Specialist"
              />
            </div>
          </div>
        </div>

        <div class="specialist-info reveal reveal-delay-1">
          <div class="eyebrow">Meet Your Specialist</div>

          <h2>Dr. Sri, BDS, MDS</h2>

          <div class="specialist-role">
            Senior Dental &amp; Implant Specialist &amp; Founder
          </div>

          <p class="desc">
            Dr. Sri is a Delhi NCR-based dental surgeon with over 10 years of
            clinical experience in endodontics, cosmetic dentistry, and
            full-mouth implant rehabilitation. Trained at a leading Indian
            dental college and certified in advanced implantology, Dr. Sri
            founded Smile Sutra with a single goal: to make quality dental care
            approachable for every family in the NCR. Over 5,000 patients from
            Delhi, Noida, Gurgaon, and Ghaziabad have been treated with a
            gentle, patient-first approach.
          </p>

          <div class="cred-grid">
            <div class="cred-item">
              <b>10+</b>
              <span>Years Experience</span>
            </div>
            <div class="cred-item">
              <b>5000+</b>
              <span>Patients Treated</span>
            </div>
            <div class="cred-item">
              <b>4.9★</b>
              <span>Patient Rating</span>
            </div>
          </div>

          <div class="cred-tags">
            <span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="margin-right:6px;"
              >
                <path d="M22 10v6M2 10v6"></path>
                <path d="M12 2l9 5-9 5-9-5 9-5z"></path>
                <path d="M6 12v5c0 1.5 2.7 3 6 3s6-1.5 6-3v-5"></path>
              </svg>
              BDS, MDS (Endodontics)
            </span>
            <span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="margin-right:6px;"
              >
                <path
                  d="M12 2c3 0 5 2.4 5 6v4c0 5-2 9-5 10-3-1-5-5-5-10V8c0-3.6 2-6 5-6z"
                ></path>
              </svg>
              Certified Implantologist
            </span>
            <span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="margin-right:6px;"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
              Hindi &amp; English
            </span>
            <span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="margin-right:6px;"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
              IDA Member
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE US ===== -->
  <section id="why-us">
    <div class="container">
      <div class="section-head reveal">
        <div class="eyebrow">Why Patients Choose Us</div>
        <h2>What makes a visit to Smile Sutra different</h2>
        <p>
          Small details, consistently done well, are what keep 5,000+ patients
          coming back.
        </p>
      </div>

      <div class="why-grid">
        <div class="why-card reveal">
          <div class="why-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 7v5l3 2"></path>
            </svg>
          </div>
          <h4>Same-day appointments</h4>
          <p>
            Emergency and walk-in slots available across all four NCR locations.
          </p>
        </div>

        <div class="why-card reveal reveal-delay-1">
          <div class="why-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M20 6L9 17l-5-5"></path>
            </svg>
          </div>
          <h4>Free first consultation</h4>
          <p>
            No charge for your initial check-up and personalised treatment plan.
          </p>
        </div>

        <div class="why-card reveal reveal-delay-2">
          <div class="why-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M12 2l2.9 6.3L22 9.3l-5 4.8 1.2 6.9L12 17.8 5.8 21l1.2-6.9-5-4.8 7.1-1L12 2z"
              ></path>
            </svg>
          </div>
          <h4>4.9-star patient rating</h4>
          <p>
            Over 800 verified Google reviews from patients across Delhi NCR.
          </p>
        </div>

        <div class="why-card reveal reveal-delay-3">
          <div class="why-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="2" y="5" width="20" height="14" rx="2"></rect>
              <path d="M2 10h20"></path>
            </svg>
          </div>
          <h4>Upfront, fair pricing</h4>
          <p>
            Transparent INR quotes and EMI options, explained before treatment
            begins.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA BAND ===== -->
  <section class="section-alt" id="cta">
    <div class="container">
      <div class="cta-band reveal">
        <div>
          <h2>Ready to experience painless, transparent dental care?</h2>
          <p>
            Book a free consultation at your nearest Smile Sutra clinic in
            Delhi, Noida, Gurgaon, or Ghaziabad.
          </p>
        </div>
        <div class="cta-actions">
          <a href="/#appointment" class="btn btn-primary"
            >Book Free Consultation</a
          >
          <a
            href="tel:+919810022334"
            class="btn btn-ghost"
            style="background:rgba(255,255,255,0.1); color:#fff; border-color:rgba(255,255,255,0.2);"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 3.09 5.18 2 2 0 0 1 5.08 3h3a2 2 0 0 1 2 1.72l.36 2.45a2 2 0 0 1-.57 1.74L8.09 10.91a16 16 0 0 0 5 5l2-2a2 2 0 0 1 1.74-.57l2.45.36A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            Call +91 98100 22334
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    :root {
      --navy: #0b3b5c;
      --navy-deep: #082c46;
      --sky: #46b7e8;
      --sky-light: #e6f5fc;
      --sky-pale: #f4fafd;
      --mint: #22b8a4;
      --white: #ffffff;
      --ink: #12293d;
      --ink-soft: #4c6478;
      --line: #dcebf3;
      --shadow-sm: 0 2px 10px rgba(11, 59, 92, 0.06);
      --shadow-md: 0 12px 30px rgba(11, 59, 92, 0.1);
      --shadow-lg: 0 24px 60px rgba(11, 59, 92, 0.16);
      --radius: 20px;
      --radius-sm: 12px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Inter", sans-serif;
      color: var(--ink);
      background: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    h1,
    h2,
    h3,
    h4 {
      font-family: "Sora", sans-serif;
      color: var(--navy);
      line-height: 1.2;
    }

    a {
      text-decoration: none;
      color: inherit;
    }
    ul {
      list-style: none;
    }
    img {
      max-width: 100%;
      display: block;
    }
    button {
      font-family: inherit;
      cursor: pointer;
      border: none;
    }

    .container {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--mint);
      background: rgba(34, 184, 164, 0.1);
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 16px;
    }
    .eyebrow::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--mint);
    }

    /* ===== Reveal animation ===== */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition:
        opacity 0.7s ease,
        transform 0.7s ease;
    }
    .reveal.in-view {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 {
      transition-delay: 0.1s;
    }
    .reveal-delay-2 {
      transition-delay: 0.2s;
    }
    .reveal-delay-3 {
      transition-delay: 0.3s;
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        animation: none !important;
        transition: none !important;
      }
    }

    /* ===== Header ===== */
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line);
    }
    .nav-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 24px;
      max-width: 1180px;
      margin: 0 auto;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: "Sora", sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: var(--navy);
    }
    .logo-mark {
      width: 38px;
      height: 38px;
      border-radius: 11px;
      background: linear-gradient(135deg, var(--sky), var(--navy));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      box-shadow: var(--shadow-sm);
    }
    .logo small {
      display: block;
      font-family: "Inter", sans-serif;
      font-weight: 500;
      font-size: 11px;
      color: var(--ink-soft);
      letter-spacing: 0.03em;
    }
    nav ul {
      display: flex;
      gap: 32px;
      align-items: center;
    }
    nav a {
      font-size: 14.5px;
      font-weight: 600;
      color: var(--navy);
      position: relative;
      padding: 6px 0;
    }
    nav a::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0;
      height: 2px;
      background: var(--sky);
      transition: width 0.25s ease;
    }
    nav a:hover::after {
      width: 100%;
    }
    nav a.active::after {
      width: 100%;
    }

    .nav-cta {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 24px;
      border-radius: 100px;
      font-weight: 700;
      font-size: 14.5px;
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease,
        background 0.2s ease;
      white-space: nowrap;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--sky), var(--navy));
      color: #fff;
      box-shadow: var(--shadow-sm);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    .btn-ghost {
      background: var(--sky-light);
      color: var(--navy);
      border: 1px solid var(--line);
    }
    .btn-ghost:hover {
      background: var(--sky);
      color: #fff;
    }
    .btn-block {
      width: 100%;
    }

    .call-chip {
      display: none;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 13.5px;
      color: var(--navy);
    }

    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      padding: 6px;
    }
    .hamburger span {
      width: 24px;
      height: 2.5px;
      background: var(--navy);
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    /* ===== Page hero (About) ===== */
    .page-hero {
      position: relative;
      background: linear-gradient(180deg, var(--sky-pale) 0%, #ffffff 100%);
      padding: 64px 0 48px;
      overflow: hidden;
    }
    .page-hero::before {
      content: "";
      position: absolute;
      top: -120px;
      right: -160px;
      width: 480px;
      height: 480px;
      border-radius: 50%;
      background: radial-gradient(
        circle,
        rgba(70, 183, 232, 0.2),
        transparent 70%
      );
    }
    .page-hero-inner {
      position: relative;
      z-index: 2;
      max-width: 720px;
    }
    .page-hero h1 {
      font-size: 42px;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .page-hero h1 span {
      color: var(--sky);
    }
    .page-hero p {
      font-size: 16.5px;
      color: var(--ink-soft);
      max-width: 560px;
    }
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 600;
      color: var(--ink-soft);
      margin-bottom: 20px;
    }
    .breadcrumb a {
      color: var(--sky);
    }
    .breadcrumb span {
      color: var(--ink-soft);
    }

    .curve-divider {
      display: block;
      width: 100%;
      line-height: 0;
    }
    .curve-divider svg {
      width: 100%;
      height: 60px;
      display: block;
    }

    /* ===== Section shared ===== */
    section {
      padding: 88px 0;
    }
    .section-head {
      max-width: 640px;
      margin-bottom: 52px;
    }
    .section-head h2 {
      font-size: 34px;
      font-weight: 800;
      letter-spacing: -0.01em;
      margin-bottom: 14px;
    }
    .section-head p {
      color: var(--ink-soft);
      font-size: 16px;
    }
    .section-alt {
      background: var(--sky-pale);
    }

    /* ===== Story / About grid ===== */
    .about-grid {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 56px;
      align-items: center;
    }
    .about-visual {
      position: relative;
      border-radius: var(--radius);
      background: linear-gradient(160deg, var(--navy), var(--sky));
      padding: 32px;
      color: #fff;
      box-shadow: var(--shadow-md);
    }
    .about-visual h3 {
      color: #fff;
      font-size: 22px;
      margin-bottom: 10px;
    }
    .about-visual p {
      color: rgba(255, 255, 255, 0.85);
      font-size: 14.5px;
      margin-bottom: 22px;
    }
    .location-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .location-tags span {
      display: inline-flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 8px 14px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 600;
    }
    .location-tags svg {
      margin-right: 6px;
    }
    .about-stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
      margin-top: 24px;
    }
    .about-stat {
      background: rgba(255, 255, 255, 0.12);
      border-radius: var(--radius-sm);
      padding: 16px;
    }
    .about-stat b {
      display: block;
      font-family: "Sora", sans-serif;
      font-size: 22px;
    }
    .about-stat span {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.8);
    }

    .about-body p {
      color: var(--ink-soft);
      margin-bottom: 16px;
      font-size: 15.5px;
    }
    .about-points {
      display: grid;
      gap: 14px;
      margin-top: 22px;
    }
    .about-point {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      padding: 16px 18px;
      box-shadow: var(--shadow-sm);
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease;
    }
    .about-point:hover {
      transform: translateX(6px);
      box-shadow: var(--shadow-md);
    }
    .about-point-icon {
      width: 38px;
      height: 38px;
      flex-shrink: 0;
      border-radius: 10px;
      background: var(--sky-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--navy);
    }
    .about-point h4 {
      font-size: 15.5px;
      margin-bottom: 3px;
    }
    .about-point p {
      font-size: 13.5px;
      color: var(--ink-soft);
      margin: 0;
    }

    /* ===== Mission / Vision / Values ===== */
    .values-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }
    .value-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 30px 26px;
      box-shadow: var(--shadow-sm);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease,
        border-color 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .value-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--sky), var(--mint));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }
    .value-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg);
      border-color: transparent;
    }
    .value-card:hover::before {
      transform: scaleX(1);
    }
    .value-icon {
      width: 54px;
      height: 54px;
      border-radius: 15px;
      background: var(--sky-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--navy);
      margin-bottom: 18px;
    }
    .value-card h3 {
      font-size: 18px;
      margin-bottom: 8px;
    }
    .value-card p {
      font-size: 14px;
      color: var(--ink-soft);
      margin: 0;
    }

    /* ===== Timeline / Journey ===== */
    .timeline {
      position: relative;
      max-width: 900px;
      margin: 0 auto;
    }
    .timeline::before {
      content: "";
      position: absolute;
      left: 19px;
      top: 6px;
      bottom: 6px;
      width: 2px;
      background: var(--line);
    }
    .timeline-item {
      position: relative;
      display: grid;
      grid-template-columns: 40px 1fr;
      gap: 24px;
      padding-bottom: 36px;
    }
    .timeline-item:last-child {
      padding-bottom: 0;
    }
    .timeline-dot {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--sky), var(--navy));
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: "Sora", sans-serif;
      font-weight: 800;
      font-size: 13px;
      box-shadow: var(--shadow-sm);
      z-index: 2;
    }
    .timeline-content {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      padding: 18px 22px;
      box-shadow: var(--shadow-sm);
    }
    .timeline-content h4 {
      font-size: 15.5px;
      margin-bottom: 4px;
    }
    .timeline-content p {
      font-size: 13.5px;
      color: var(--ink-soft);
      margin: 0;
    }

    /* ===== Specialist ===== */
    .specialist {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: 52px;
      align-items: center;
      background: linear-gradient(135deg, var(--navy), var(--navy-deep));
      border-radius: 28px;
      padding: 52px;
      color: #fff;
      position: relative;
      overflow: hidden;
    }
    .specialist::after {
      content: "";
      position: absolute;
      bottom: -100px;
      left: -100px;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: radial-gradient(
        circle,
        rgba(70, 183, 232, 0.25),
        transparent 70%
      );
    }
    .specialist-photo {
      position: relative;
      z-index: 2;
    }
    .specialist-photo-frame {
      width: 100%;
      aspect-ratio: 1/1.05;
      border-radius: 22px;
      background: linear-gradient(160deg, var(--sky), #fff2);
      padding: 5px;
    }
    .specialist-photo-inner {
      width: 100%;
      height: 100%;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: flex-end;
      justify-content: center;
      overflow: hidden;
    }
    .specialist-photo-inner img.doctor-silhouette {
      max-width: 100%;
      height: 100%;
      object-fit: cover;
      width: 100%;
    }
    .specialist-info {
      position: relative;
      z-index: 2;
    }
    .specialist-info .eyebrow {
      background: rgba(255, 255, 255, 0.12);
      color: #8fe0d3;
    }
    .specialist-info .eyebrow::before {
      background: #8fe0d3;
    }
    .specialist-info h2 {
      color: #fff;
      font-size: 30px;
      margin-bottom: 6px;
    }
    .specialist-role {
      color: var(--sky);
      font-weight: 700;
      font-size: 14.5px;
      margin-bottom: 18px;
    }
    .specialist-info p.desc {
      color: rgba(255, 255, 255, 0.82);
      font-size: 15px;
      margin-bottom: 24px;
      max-width: 520px;
    }
    .cred-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 26px;
    }
    .cred-item {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 14px;
      padding: 16px;
      text-align: center;
    }
    .cred-item b {
      display: block;
      font-family: "Sora", sans-serif;
      font-size: 21px;
      color: #fff;
    }
    .cred-item span {
      font-size: 11.5px;
      color: rgba(255, 255, 255, 0.75);
    }
    .cred-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
    }
    .cred-tags span {
      display: inline-flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      padding: 7px 13px;
      border-radius: 100px;
      font-size: 12.5px;
    }

    /* ===== Why choose us strip ===== */
    .why-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .why-card {
      text-align: center;
      padding: 26px 18px;
    }
    .why-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: var(--sky-light);
      color: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
    }
    .why-card h4 {
      font-size: 15.5px;
      margin-bottom: 6px;
    }
    .why-card p {
      font-size: 13px;
      color: var(--ink-soft);
      margin: 0;
    }

    /* ===== CTA band ===== */
    .cta-band {
      background: linear-gradient(135deg, var(--navy), var(--navy-deep));
      border-radius: 28px;
      padding: 52px;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;
      flex-wrap: wrap;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: "";
      position: absolute;
      top: -90px;
      right: -90px;
      width: 280px;
      height: 280px;
      border-radius: 50%;
      background: radial-gradient(
        circle,
        rgba(70, 183, 232, 0.3),
        transparent 70%
      );
    }
    .cta-band h2 {
      color: #fff;
      font-size: 28px;
      margin-bottom: 8px;
      position: relative;
      z-index: 2;
    }
    .cta-band p {
      color: rgba(255, 255, 255, 0.8);
      font-size: 15px;
      position: relative;
      z-index: 2;
    }
    .cta-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      position: relative;
      z-index: 2;
    }

    /* ===== Footer ===== */
    footer {
      background: var(--navy-deep);
      color: rgba(255, 255, 255, 0.75);
      padding: 64px 0 24px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
      gap: 36px;
      margin-bottom: 48px;
    }
    .footer-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: "Sora", sans-serif;
      font-weight: 800;
      font-size: 19px;
      color: #fff;
      margin-bottom: 14px;
    }
    footer p {
      font-size: 13.5px;
      line-height: 1.7;
    }
    footer h5 {
      color: #fff;
      font-family: "Sora", sans-serif;
      font-size: 14.5px;
      margin-bottom: 16px;
    }
    footer ul li {
      margin-bottom: 10px;
    }
    footer ul li a {
      font-size: 13.5px;
      transition: color 0.2s ease;
    }
    footer ul li a:hover {
      color: var(--sky);
    }
    footer ul li {
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }
    .footer-social {
      display: flex;
      gap: 10px;
      margin-top: 16px;
    }
    .footer-social a {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      transition:
        background 0.2s ease,
        transform 0.2s ease;
    }
    .footer-social a:hover {
      background: var(--sky);
      transform: translateY(-3px);
    }
    .footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 22px;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 12.5px;
    }

    /* ===== WhatsApp float ===== */
    .wa-float {
      position: fixed;
      bottom: 24px;
      right: 24px;
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: #25d366;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 26px rgba(37, 211, 102, 0.45);
      z-index: 900;
      animation: pulseWa 2.4s ease-in-out infinite;
    }
    @keyframes pulseWa {
      0%,
      100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.08);
      }
    }

    /* ===== Responsive ===== */
    @media (max-width: 980px) {
      .about-grid,
      .specialist {
        grid-template-columns: 1fr;
      }
      .specialist {
        padding: 36px 26px;
      }
      .specialist-photo {
        max-width: 320px;
        margin: 0 auto;
      }
      .values-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .why-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .footer-grid {
        grid-template-columns: 1fr 1fr;
      }
      .page-hero h1 {
        font-size: 34px;
      }
      .cta-band {
        flex-direction: column;
        text-align: center;
      }
    }

    @media (max-width: 720px) {
      nav,
      .call-chip {
        display: none;
      }
      .hamburger {
        display: flex;
      }
      .btn-primary.nav-book {
        display: none;
      }
      section {
        padding: 64px 0;
      }
      .page-hero {
        padding: 40px 0 26px;
      }
      .page-hero h1 {
        font-size: 28px;
      }
      .values-grid {
        grid-template-columns: 1fr;
      }
      .why-grid {
        grid-template-columns: 1fr;
      }
      .footer-grid {
        grid-template-columns: 1fr;
      }
      .cred-grid {
        grid-template-columns: repeat(3, 1fr);
      }
      .section-head h2 {
        font-size: 27px;
      }
      .timeline::before {
        left: 15px;
      }
      .timeline-item {
        grid-template-columns: 32px 1fr;
        gap: 16px;
      }
      .timeline-dot {
        width: 32px;
        height: 32px;
        font-size: 11px;
      }
    }
  </style>
  <script is:inline>
          const hamburgerBtn = document.getElementById("hamburgerBtn");
      const closeDrawer = document.getElementById("closeDrawer");
      const mobileNav = document.getElementById("mobileNav");
      const navOverlay = document.getElementById("navOverlay");

      function openDrawer() {
        mobileNav.classList.add("open");
        navOverlay.classList.add("open");
      }
      function closeDrawerFn() {
        mobileNav.classList.remove("open");
        navOverlay.classList.remove("open");
      }
      hamburgerBtn.addEventListener("click", openDrawer);
      closeDrawer.addEventListener("click", closeDrawerFn);
      navOverlay.addEventListener("click", closeDrawerFn);
      mobileNav
        .querySelectorAll("a")
        .forEach((a) => a.addEventListener("click", closeDrawerFn));

    // Scroll reveal
    const revealEls = document.querySelectorAll(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    revealEls.forEach((el) => io.observe(el));

    // Header shadow on scroll
    const headerEl = document.querySelector("header");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 10) {
        headerEl.style.boxShadow = "0 4px 20px rgba(11,59,92,0.08)";
      } else {
        headerEl.style.boxShadow = "none";
      }
    });
  </script>
</Layout>
