---
import AboutHeroImage from "../assets/blog-placeholder-about.jpg";
import Layout from "../layouts/BlogPost.astro";
---

<Layout
  title="Contact Smile Sutra Dental Clinic | Book a Dentist Appointment in Delhi NCR"
  description="Contact Smile Sutra Dental Clinic to book your dental appointment. Call, WhatsApp, or email our team for dental implants, root canal treatment, cosmetic dentistry, emergency dental care, and family dentistry in Delhi NCR."
  pubDate={new Date("August 08 2021")}
  heroImage={AboutHeroImage}
>
  <!-- ===== CONTACT HERO ===== -->
  <section class="contact-hero" id="top">
    <div class="container contact-hero-grid">
      <div class="contact-hero-copy reveal in-view">
        <div class="eyebrow">Get in Touch</div>
        <h1>We're here to help you <span>smile again</span></h1>
        <p>
          Have a question, need an appointment, or want to visit our clinic?
          Reach out through any channel that works for you — our team responds
          within 30 minutes during clinic hours.
        </p>

        <div class="hero-contact-row">
          <a href="tel:+919810022334" class="hero-contact-item">
            <span class="hero-contact-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 3.09 5.18 2 2 0 0 1 5.08 3h3a2 2 0 0 1 2 1.72l.36 2.45a2 2 0 0 1-.57 1.74L8.09 10.91a16 16 0 0 0 5 5l2-2a2 2 0 0 1 1.74-.57l2.45.36A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
            </span>
            <div>
              <b>Call us</b>
              <span>+91 98100 22334</span>
            </div>
          </a>

          <a href="https://wa.me/919810022334" class="hero-contact-item">
            <span
              class="hero-contact-icon"
              style="background:#E8F9F0; color:#25D366;"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 32 32"
                fill="currentColor"
              >
                <path
                  d="M19.11 17.21c-.28-.14-1.65-.81-1.9-.9-.25-.09-.43-.14-.61.14-.18.28-.7.9-.86 1.09-.16.19-.31.21-.58.07-.28-.14-1.17-.43-2.23-1.37-.83-.74-1.39-1.65-1.55-1.93-.16-.28-.02-.43.12-.57.13-.13.28-.33.42-.49.14-.16.19-.28.28-.46.09-.19.05-.35-.02-.49-.07-.14-.61-1.48-.84-2.03-.22-.53-.44-.46-.61-.47h-.52c-.18 0-.46.07-.7.33-.24.26-.92.9-.92 2.2 0 1.3.94 2.56 1.07 2.73.14.18 1.85 2.82 4.48 3.95.63.27 1.12.43 1.5.55.63.2 1.21.17 1.66.1.51-.08 1.65-.67 1.88-1.31.23-.64.23-1.19.16-1.31-.07-.11-.25-.18-.53-.32z"
                ></path>
                <path
                  d="M16.01 3C8.83 3 3 8.82 3 16c0 2.54.75 5.02 2.16 7.14L3 29l5.98-2.1A12.93 12.93 0 0016.01 29C23.18 29 29 23.18 29 16S23.18 3 16.01 3zm0 23.5c-2.12 0-4.18-.57-5.98-1.65l-.43-.25-3.55 1.25 1.19-3.46-.28-.45A10.47 10.47 0 015.5 16C5.5 10.2 10.2 5.5 16.01 5.5S26.5 10.2 26.5 16 21.8 26.5 16.01 26.5z"
                ></path>
              </svg>
            </span>
            <div>
              <b>WhatsApp</b>
              <span>Chat with us</span>
            </div>
          </a>

          <a href="mailto:care@smilesutraclinic.in" class="hero-contact-item">
            <span class="hero-contact-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                <polyline points="3 7 12 13 21 7"></polyline>
              </svg>
            </span>
            <div>
              <b>Email</b>
              <span>care@smilesutra.in</span>
            </div>
          </a>

          <div class="hero-contact-item">
            <span class="hero-contact-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <polyline points="12 7 12 12 15 15"></polyline>
              </svg>
            </span>
            <div>
              <b>Hours</b>
              <span>Mon–Sun · 9AM–8PM</span>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-hero-visual reveal reveal-delay-2 in-view">
        <img src="/assets/img/contact.png" alt="Smile Sutra clinic reception" />
        <div class="hero-visual-badge">
          <span class="hero-visual-badge-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </span>
          <div>
            <b>Response within 30 minutes</b>
            <span>During clinic hours, 7 days a week</span>
          </div>
        </div>
      </div>
    </div>

    <div class="curve-divider">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none">
        <path
          d="M0,32 C240,64 480,0 720,20 C960,40 1200,64 1440,24 L1440,60 L0,60 Z"
          fill="#FFFFFF"></path>
      </svg>
    </div>
  </section>

  <!-- ===== QUICK CONTACT CARDS ===== -->
  <section>
    <div class="container">
      <div class="section-head center reveal">
        <div class="eyebrow">Reach Us Anytime</div>
        <h2>Multiple ways to connect with us</h2>
        <p>
          Choose the channel that suits you best — we're always just a message
          or call away.
        </p>
      </div>

      <div class="quick-grid">
        <a href="tel:+919810022334" class="quick-card reveal">
          <span class="quick-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 3.09 5.18 2 2 0 0 1 5.08 3h3a2 2 0 0 1 2 1.72l.36 2.45a2 2 0 0 1-.57 1.74L8.09 10.91a16 16 0 0 0 5 5l2-2a2 2 0 0 1 1.74-.57l2.45.36A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
          </span>
          <h3>Call Us</h3>
          <p>Speak directly with our front desk team</p>
          <span>+91 98100 22334 →</span>
        </a>

        <a
          href="https://wa.me/919810022334"
          class="quick-card reveal reveal-delay-1"
        >
          <span class="quick-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="26"
              viewBox="0 0 32 32"
              fill="currentColor"
            >
              <path
                d="M19.11 17.21c-.28-.14-1.65-.81-1.9-.9-.25-.09-.43-.14-.61.14-.18.28-.7.9-.86 1.09-.16.19-.31.21-.58.07-.28-.14-1.17-.43-2.23-1.37-.83-.74-1.39-1.65-1.55-1.93-.16-.28-.02-.43.12-.57.13-.13.28-.33.42-.49.14-.16.19-.28.28-.46.09-.19.05-.35-.02-.49-.07-.14-.61-1.48-.84-2.03-.22-.53-.44-.46-.61-.47h-.52c-.18 0-.46.07-.7.33-.24.26-.92.9-.92 2.2 0 1.3.94 2.56 1.07 2.73.14.18 1.85 2.82 4.48 3.95.63.27 1.12.43 1.5.55.63.2 1.21.17 1.66.1.51-.08 1.65-.67 1.88-1.31.23-.64.23-1.19.16-1.31-.07-.11-.25-.18-.53-.32z"
              ></path>
              <path
                d="M16.01 3C8.83 3 3 8.82 3 16c0 2.54.75 5.02 2.16 7.14L3 29l5.98-2.1A12.93 12.93 0 0016.01 29C23.18 29 29 23.18 29 16S23.18 3 16.01 3zm0 23.5c-2.12 0-4.18-.57-5.98-1.65l-.43-.25-3.55 1.25 1.19-3.46-.28-.45A10.47 10.47 0 015.5 16C5.5 10.2 10.2 5.5 16.01 5.5S26.5 10.2 26.5 16 21.8 26.5 16.01 26.5z"
              ></path>
            </svg>
          </span>
          <h3>WhatsApp</h3>
          <p>Quick chat for appointments &amp; queries</p>
          <span>Chat now →</span>
        </a>

        <a
          href="mailto:care@smilesutraclinic.in"
          class="quick-card reveal reveal-delay-2"
        >
          <span class="quick-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <polyline points="3 7 12 13 21 7"></polyline>
            </svg>
          </span>
          <h3>Email</h3>
          <p>For detailed queries &amp; collaborations</p>
          <span>care@smilesutra.in →</span>
        </a>

        <a href="#map" class="quick-card reveal reveal-delay-3">
          <span class="quick-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="26"
              height="26"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </span>
          <h3>Visit Us</h3>
          <p>Walk-in at any of our 4 NCR branches</p>
          <span>Get directions →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT FORM ===== -->
  <section class="section-alt" id="form">
    <div class="container form-wrap">
      <div class="form-side reveal">
        <div class="eyebrow">Send a Message</div>
        <h2>Drop us a line — we'll get back to you fast</h2>
        <p>
          Whether you have a question about our treatments, need pricing
          details, or want to schedule a visit, fill out the form and our team
          will respond within 30 minutes during clinic hours.
        </p>

        <div class="form-perks">
          <div class="form-perk">
            <span class="perk-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 7v5l3 2"></path>
              </svg>
            </span>
            <div>
              <h4>30-minute response</h4>
              <p>
                We reply to every message within half an hour during clinic
                hours.
              </p>
            </div>
          </div>

          <div class="form-perk">
            <span class="perk-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
            </span>
            <div>
              <h4>100% confidential</h4>
              <p>
                Your details are safe with us and never shared with third
                parties.
              </p>
            </div>
          </div>

          <div class="form-perk">
            <span class="perk-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </span>
            <div>
              <h4>Hindi &amp; English</h4>
              <p>
                Our team responds in your preferred language — Hindi or English.
              </p>
            </div>
          </div>

          <div class="form-perk">
            <span class="perk-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
            </span>
            <div>
              <h4>Free consultation</h4>
              <p>
                Your first consultation and treatment plan are completely free.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-1">
        <form class="contact-form" id="contactForm">
          <div id="form-fields">
            <div class="form-row">
              <div class="form-group">
                <label for="cfname">Full Name</label>
                <input
                  type="text"
                  id="cfname"
                  placeholder="e.g. Priya Sharma"
                  required
                />
              </div>
              <div class="form-group">
                <label for="cfemail">Email Address</label>
                <input
                  type="email"
                  id="cfemail"
                  placeholder="you@example.com"
                  required
                />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group full">
                <label for="cfphone">Phone Number</label>
                <div class="phone-wrap">
                  <span>+91</span>
                  <input
                    type="tel"
                    id="cfphone"
                    placeholder="98XXX XXXXX"
                    pattern="[0-9]{10}"
                    maxlength="10"
                    required
                  />
                </div>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="cfsubject">Subject</label>
                <select id="cfsubject" required>
                  <option value="" disabled selected>Select subject</option>
                  <option>General Enquiry</option>
                  <option>Appointment Booking</option>
                  <option>Treatment Pricing</option>
                  <option>Insurance &amp; EMI</option>
                  <option>Feedback</option>
                  <option>Partnership / Collaboration</option>
                </select>
              </div>
              <div class="form-group">
                <label for="cflocation">Preferred Location</label>
                <select id="cflocation" required>
                  <option value="" disabled selected>Select location</option>
                  <option>Laxmi Nagar, Delhi</option>
                  <option>Sector 62, Noida</option>
                  <option>DLF Phase 3, Gurgaon</option>
                  <option>Vaishali, Ghaziabad</option>
                  <option>Not sure yet</option>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group full">
                <label for="cfmessage">Your Message</label>
                <textarea
                  id="cfmessage"
                  placeholder="Tell us how we can help you..."
                  required></textarea>
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
              Send Message
            </button>

            <p class="form-note">
              By submitting, you agree to be contacted via call/email/WhatsApp
              for your enquiry.
            </p>
          </div>

          <div id="form-success">
            <span class="success-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <h3>Message received!</h3>
            <p>
              Thank you for reaching out. Our team will get back to you within
              30 minutes during clinic hours. We look forward to helping you
              smile.
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== BRANCHES ===== -->
  <section id="branches">
    <div class="container">
      <div class="section-head center reveal">
        <div class="eyebrow">Our Locations</div>
        <h2>Four clinics across Delhi NCR</h2>
        <p>
          Find the Smile Sutra branch closest to you. All clinics offer the same
          high standards of care, hygiene, and expertise.
        </p>
      </div>

      <div class="branches-grid">
        <div class="branch-card reveal">
          <div class="branch-photo">
            <img
              src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=900&q=80"
              alt="Smile Sutra Delhi Clinic"
              loading="lazy"
            />
            <span class="branch-tag">Main Branch</span>
          </div>
          <div class="branch-body">
            <h3>Laxmi Nagar, Delhi</h3>
            <div class="branch-address">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span
                >2nd Floor, Aggarwal Complex, Vikas Marg, Laxmi Nagar, New Delhi
                – 110092</span
              >
            </div>
            <div class="branch-meta">
              <div class="branch-meta-item">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 3.09 5.18 2 2 0 0 1 5.08 3h3a2 2 0 0 1 2 1.72l.36 2.45a2 2 0 0 1-.57 1.74L8.09 10.91a16 16 0 0 0 5 5l2-2a2 2 0 0 1 1.74-.57l2.45.36A2 2 0 0 1 22 16.92z"
                  ></path>
                </svg>
                <a href="tel:+919810022334">+91 98100 22334</a>
              </div>
              <div class="branch-meta-item">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="9"></circle>
                  <polyline points="12 7 12 12 15 15"></polyline>
                </svg>
                Mon–Sun · 9:00 AM – 8:00 PM
              </div>
            </div>
            <a
              href="https://www.google.com/maps?q=Laxmi+Nagar+New+Delhi"
              target="_blank"
              rel="noopener"
              class="branch-directions"
            >
              Get Directions
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>

        <div class="branch-card reveal reveal-delay-1">
          <div class="branch-photo">
            <img
              src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=900&q=80"
              alt="Smile Sutra Noida Clinic"
              loading="lazy"
            />
            <span class="branch-tag">Noida</span>
          </div>
          <div class="branch-body">
            <h3>Sector 62, Noida</h3>
            <div class="branch-address">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span
                >B-45, Sector 62, Near Metro Station, Noida, Uttar Pradesh –
                201301</span
              >
            </div>
            <div class="branch-meta">
              <div class="branch-meta-item">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
