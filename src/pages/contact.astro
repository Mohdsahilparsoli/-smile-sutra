  <style>
    /* ===== Contact Hero ===== */
    .contact-hero {
      position: relative;
      background: linear-gradient(180deg, var(--sky-pale) 0%, #ffffff 100%);
      padding: 80px 0 60px;
      overflow: hidden;
    }
    .contact-hero::before {
      content: "";
      position: absolute;
      top: -120px;
      right: -160px;
      width: 480px;
      height: 480px;
      border-radius: 50%;
      background: radial-gradient(
        circle,
        rgba(70, 183, 232, 0.2),
        transparent 70%
      );
    }
    .contact-hero::after {
      content: "";
      position: absolute;
      bottom: -100px;
      left: -120px;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      background: radial-gradient(
        circle,
        rgba(34, 184, 164, 0.15),
        transparent 70%
      );
    }
    .contact-hero-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 56px;
      align-items: center;
      position: relative;
      z-index: 2;
    }
    .contact-hero-copy h1 {
      font-size: 48px;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 18px;
    }
    .contact-hero-copy h1 span {
      color: var(--sky);
    }
    .contact-hero-copy p {
      font-size: 17px;
      color: var(--ink-soft);
      max-width: 520px;
      margin-bottom: 28px;
    }
    .hero-contact-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
      max-width: 520px;
    }
    .hero-contact-item {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px 16px;
      box-shadow: var(--shadow-sm);
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease;
    }
    .hero-contact-item:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }
    .hero-contact-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: var(--sky-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--navy);
      flex-shrink: 0;
    }
    .hero-contact-item b {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--ink-soft);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 2px;
    }
    .hero-contact-item a,
    .hero-contact-item span {
      font-size: 14px;
      font-weight: 700;
      color: var(--navy);
    }
    .hero-contact-item a:hover {
      color: var(--sky);
    }

    .contact-hero-visual {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      aspect-ratio: 4/3;
    }
    .contact-hero-visual img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .hero-visual-badge {
      position: absolute;
      bottom: 20px;
      left: 20px;
      right: 20px;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      box-shadow: var(--shadow-md);
    }
    .hero-visual-badge-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--mint), #5adfcb);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      flex-shrink: 0;
    }
    .hero-visual-badge b {
      display: block;
      font-family: "Sora", sans-serif;
      font-size: 14px;
      color: var(--navy);
      margin-bottom: 2px;
    }
    .hero-visual-badge span {
      font-size: 12px;
      color: var(--ink-soft);
    }

    .curve-divider {
      display: block;
      width: 100%;
      line-height: 0;
    }
    .curve-divider svg {
      width: 100%;
      height: 60px;
      display: block;
    }

    /* ===== Section shared ===== */
    section {
      padding: 88px 0;
    }
    .section-head {
      max-width: 640px;
      margin-bottom: 52px;
    }
    .section-head.center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }
    .section-head h2 {
      font-size: 34px;
      font-weight: 800;
      letter-spacing: -0.01em;
      margin-bottom: 14px;
    }
    .section-head p {
      color: var(--ink-soft);
      font-size: 16px;
    }
    .section-alt {
      background: var(--sky-pale);
    }

    /* ===== Quick Contact Cards ===== */
    .quick-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .quick-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 28px 24px;
      box-shadow: var(--shadow-sm);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease,
        border-color 0.3s ease;
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .quick-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--sky), var(--mint));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }
    .quick-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg);
      border-color: transparent;
    }
    .quick-card:hover::before {
      transform: scaleX(1);
    }
    .quick-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: var(--sky-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--navy);
      margin: 0 auto 16px;
      transition:
        background 0.3s ease,
        color 0.3s ease;
    }
    .quick-card:hover .quick-icon {
      background: linear-gradient(135deg, var(--sky), var(--navy));
      color: #fff;
    }
    .quick-card h3 {
      font-size: 15px;
      margin-bottom: 6px;
    }
    .quick-card p {
      font-size: 13px;
      color: var(--ink-soft);
      margin-bottom: 12px;
    }
    .quick-card a {
      font-size: 14px;
      font-weight: 700;
      color: var(--sky);
      display: inline-flex;
      align-items: center;
      gap: 4px;
      transition: gap 0.2s ease;
    }
    .quick-card:hover a {
      gap: 8px;
    }

    /* ===== Contact Form Section ===== */
    .form-wrap {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 44px;
      align-items: flex-start;
    }
    .form-side h2 {
      font-size: 32px;
      margin-bottom: 16px;
    }
    .form-side p {
      color: var(--ink-soft);
      font-size: 15.5px;
      margin-bottom: 26px;
    }
    .form-perks {
      display: grid;
      gap: 16px;
    }
    .form-perk {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }
    .form-perk .perk-icon {
      width: 40px;
      height: 40px;
      border-radius: 11px;
      background: var(--sky-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--navy);
      flex-shrink: 0;
    }
    .form-perk h4 {
      font-size: 14.5px;
      margin-bottom: 2px;
    }
    .form-perk p {
      font-size: 13px;
      margin: 0;
      color: var(--ink-soft);
    }

    .contact-form {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 34px;
      box-shadow: var(--shadow-md);
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-group.full {
      grid-column: 1/-1;
    }
    .form-group label {
      font-size: 13px;
      font-weight: 700;
      color: var(--navy);
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      border: 1.5px solid var(--line);
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 14.5px;
      font-family: inherit;
      color: var(--ink);
      background: var(--sky-pale);
      transition:
        border-color 0.2s ease,
        background 0.2s ease;
    }
    .form-group textarea {
      resize: vertical;
      min-height: 110px;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--sky);
      background: #fff;
    }
    .phone-wrap {
      display: flex;
      align-items: center;
      border: 1.5px solid var(--line);
      border-radius: 12px;
      background: var(--sky-pale);
      overflow: hidden;
      transition:
        border-color 0.2s ease,
        background 0.2s ease;
    }
    .phone-wrap:focus-within {
      border-color: var(--sky);
      background: #fff;
    }
    .phone-wrap span {
      padding: 12px 12px;
      font-weight: 700;
      color: var(--navy);
      border-right: 1.5px solid var(--line);
      font-size: 14.5px;
    }
    .phone-wrap input {
      border: none;
      background: transparent;
      flex: 1;
      padding: 12px 14px;
      font-size: 14.5px;
      font-family: inherit;
    }
    .phone-wrap input:focus {
      outline: none;
    }
    .form-note {
      font-size: 12px;
      color: var(--ink-soft);
      margin-top: 14px;
      text-align: center;
    }
    #form-success {
      display: none;
      text-align: center;
      padding: 40px 10px;
    }
    #form-success .success-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 16px;
      background: var(--mint);
      color: #fff;
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #form-success h3 {
      margin-bottom: 8px;
    }
    #form-success p {
      color: var(--ink-soft);
      font-size: 14.5px;
    }

    /* ===== Branches ===== */
    .branches-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .branch-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
    }
    .branch-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-md);
    }
    .branch-photo {
      aspect-ratio: 16/10;
      overflow: hidden;
      position: relative;
    }
    .branch-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .branch-card:hover .branch-photo img {
      transform: scale(1.08);
    }
    .branch-tag {
      position: absolute;
      top: 12px;
      left: 12px;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(8px);
      color: var(--navy);
      padding: 5px 12px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .branch-tag::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--mint);
    }
    .branch-body {
      padding: 22px 20px;
    }
    .branch-body h3 {
      font-size: 17px;
      margin-bottom: 8px;
    }
    .branch-body .branch-address {
      font-size: 13px;
      color: var(--ink-soft);
      margin-bottom: 14px;
      display: flex;
      gap: 8px;
      align-items: flex-start;
    }
    .branch-body .branch-address svg {
      flex-shrink: 0;
      margin-top: 2px;
      color: var(--sky);
    }
    .branch-meta {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-top: 14px;
      border-top: 1px dashed var(--line);
    }
    .branch-meta-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12.5px;
      color: var(--ink-soft);
    }
    .branch-meta-item svg {
      color: var(--sky);
      flex-shrink: 0;
    }
    .branch-meta-item a {
      color: var(--navy);
      font-weight: 700;
    }
    .branch-meta-item a:hover {
      color: var(--sky);
    }
    .branch-directions {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 14px;
      font-size: 13px;
      font-weight: 700;
      color: var(--sky);
      transition: gap 0.2s ease;
    }
    .branch-directions:hover {
      gap: 10px;
    }

    /* ===== Map ===== */
    .map-section {
      padding: 60 0 88px;
    }
    .map-container {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      border: 1px solid var(--line);
    }
    .map-container iframe {
      width: 100%;
      height: 480px;
      border: 0;
      display: block;
    }
    .map-overlay-card {
      position: absolute;
      top: 24px;
      right: 24px;
      background: #fff;
      border-radius: 18px;
      padding: 22px;
      box-shadow: var(--shadow-lg);
      max-width: 320px;
      z-index: 2;
    }
    .map-overlay-card h3 {
      font-size: 16px;
      margin-bottom: 4px;
    }
    .map-overlay-card .map-address {
      font-size: 13px;
      color: var(--ink-soft);
      margin-bottom: 14px;
    }
    .map-overlay-card .map-actions {
      display: flex;
      gap: 8px;
    }
    .map-overlay-card .map-actions a {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 9px 12px;
      border-radius: 10px;
      font-size: 12.5px;
      font-weight: 700;
      transition: all 0.2s ease;
    }
    .map-overlay-card .map-actions a.primary {
      background: linear-gradient(135deg, var(--sky), var(--navy));
      color: #fff;
    }
    .map-overlay-card .map-actions a.secondary {
      background: var(--sky-light);
      color: var(--navy);
    }

    /* ===== FAQ ===== */
    .faq-wrap {
      max-width: 820px;
      margin: 0 auto;
    }
    .faq-item {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      margin-bottom: 12px;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition:
        border-color 0.25s ease,
        box-shadow 0.25s ease;
    }
    .faq-item:hover {
      border-color: var(--sky);
    }
    .faq-item.open {
      border-color: var(--sky);
      box-shadow: var(--shadow-md);
    }
    .faq-question {
      width: 100%;
      padding: 18px 22px;
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      text-align: left;
      font-size: 15px;
      font-weight: 700;
      color: var(--navy);
      font-family: "Sora", sans-serif;
    }
    .faq-toggle {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--sky-light);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--navy);
      flex-shrink: 0;
      transition:
        transform 0.3s ease,
        background 0.3s ease,
        color 0.3s ease;
    }
    .faq-item.open .faq-toggle {
      transform: rotate(45deg);
      background: var(--sky);
      color: #fff;
    }
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
    }
    .faq-answer-inner {
      padding: 0 22px 20px;
      font-size: 14.5px;
      color: var(--ink-soft);
      line-height: 1.7;
    }

    /* ===== CTA ===== */
    .cta-section {
      background: linear-gradient(135deg, var(--navy), var(--navy-deep));
      border-radius: 28px;
      padding: 60px 52px;
      color: #fff;
      position: relative;
      overflow: hidden;
    }
    .cta-section::after {
      content: "";
      position: absolute;
      bottom: -100px;
      right: -100px;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: radial-gradient(
        circle,
        rgba(70, 183, 232, 0.25),
        transparent 70%
      );
    }
    .cta-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 40px;
      align-items: center;
      position: relative;
      z-index: 2;
    }
    .cta-copy .eyebrow {
      background: rgba(255, 255, 255, 0.12);
      color: #8fe0d3;
    }
    .cta-copy .eyebrow::before {
      background: #8fe0d3;
    }
    .cta-copy h2 {
      color: #fff;
      font-size: 32px;
      margin-bottom: 14px;
    }
    .cta-copy p {
      color: rgba(255, 255, 255, 0.82);
      font-size: 15.5px;
      margin-bottom: 26px;
      max-width: 520px;
    }
    .cta-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }
    .cta-actions .btn-primary {
      background: #fff;
      color: var(--navy);
    }
    .cta-actions .btn-primary:hover {
      background: var(--sky-light);
    }
    .cta-actions .btn-ghost {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      border-color: rgba(255, 255, 255, 0.2);
    }
    .cta-actions .btn-ghost:hover {
      background: rgba(255, 255, 255, 0.2);
    }
    .cta-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    .cta-stat {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 14px;
      padding: 20px;
      text-align: center;
    }
    .cta-stat b {
      display: block;
      font-family: "Sora", sans-serif;
      font-size: 26px;
      color: #fff;
    }
    .cta-stat span {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.75);
    }

    /* ===== Responsive ===== */
    @media (max-width: 980px) {
      .contact-hero-grid,
      .form-wrap,
      .cta-grid {
        grid-template-columns: 1fr;
      }
      .quick-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .branches-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .footer-grid {
        grid-template-columns: 1fr 1fr;
      }
      .contact-hero-copy h1 {
        font-size: 38px;
      }
      .cta-section {
        padding: 40px 28px;
      }
      .map-overlay-card {
        position: relative;
        top: auto;
        left: auto;
        right: auto;
        max-width: 100%;
        border-radius: 0 0 var(--radius) var(--radius);
        margin: 0;
      }
    }

    @media (max-width: 720px) {
      nav,
      .call-chip {
        display: none;
      }
      .hamburger {
        display: flex;
      }
      .btn-primary.nav-book {
        display: none;
      }
      section {
        padding: 64px 0;
      }
      .contact-hero {
        padding: 44px 0 30px;
      }
      .contact-hero-copy h1 {
        font-size: 32px;
      }
      .hero-contact-row {
        grid-template-columns: 1fr;
      }
      .quick-grid {
        grid-template-columns: 1fr;
      }
      .branches-grid {
        grid-template-columns: 1fr;
      }
      .form-row {
        grid-template-columns: 1fr;
      }
      .footer-grid {
        grid-template-columns: 1fr;
      }
      .section-head h2 {
        font-size: 27px;
      }
      .contact-form {
        padding: 24px;
      }
      .map-container iframe {
        height: 360px;
      }
    }
  </style>

  <script is:inline>
    // Mobile nav drawer

    // Scroll reveal
    const revealEls = document.querySelectorAll(".reveal");

    if (revealEls.length) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in-view");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );

      revealEls.forEach((el) => io.observe(el));
    }

    // Contact form submit
    const contactForm = document.getElementById("contactForm");

    if (contactForm) {
      contactForm.addEventListener("submit", function (e) {
        e.preventDefault();

        const formFields = document.getElementById("form-fields");
        const formSuccess = document.getElementById("form-success");

        if (formFields) formFields.style.display = "none";
        if (formSuccess) formSuccess.style.display = "block";
      });
    }

    // FAQ accordion
    document.querySelectorAll(".faq-question").forEach((btn) => {
      btn.addEventListener("click", () => {
        const item = btn.parentElement;
        const answer = item?.querySelector(".faq-answer");

        if (!item || !answer) return;

        const isOpen = item.classList.contains("open");

        // Close all
        document.querySelectorAll(".faq-item").forEach((faqItem) => {
          faqItem.classList.remove("open");

          const faqAnswer = faqItem.querySelector(".faq-answer");
          if (faqAnswer) {
            faqAnswer.style.maxHeight = null;
          }
        });

        // Open clicked item
        if (!isOpen) {
          item.classList.add("open");
          answer.style.maxHeight = answer.scrollHeight + "px";
        }
      });
    });

    // Header shadow on scroll
    const headerEl = document.querySelector("header");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 10) {
        headerEl.style.boxShadow = "0 4px 20px rgba(11,59,92,0.08)";
      } else {
        headerEl.style.boxShadow = "none";
      }
    });
  </script>
</Layout>
