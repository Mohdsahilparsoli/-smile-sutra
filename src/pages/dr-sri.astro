      nav ul {
        display: flex;
        gap: 32px;
        align-items: center;
      }
      nav a {
        font-size: 14.5px;
        font-weight: 600;
        color: var(--navy);
        position: relative;
        padding: 6px 0;
      }
      nav a::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 0;
        width: 0;
        height: 2px;
        background: var(--sky);
        transition: width 0.25s ease;
      }
      nav a:hover::after {
        width: 100%;
      }

      .nav-cta {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 14.5px;
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          background 0.2s ease;
        white-space: nowrap;
      }
      .btn-primary {
        background: linear-gradient(135deg, var(--sky), var(--navy));
        color: #fff;
        box-shadow: var(--shadow-sm);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
      }
      .btn-ghost {
        background: var(--sky-light);
        color: var(--navy);
        border: 1px solid var(--line);
      }
      .btn-ghost:hover {
        background: var(--sky);
        color: #fff;
      }
      .btn-block {
        width: 100%;
      }

      .call-chip {
        display: none;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        font-size: 13.5px;
        color: var(--navy);
      }

      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        padding: 6px;
      }
      .hamburger span {
        width: 24px;
        height: 2.5px;
        background: var(--navy);
        border-radius: 2px;
        transition: all 0.3s ease;
      }

      /* ===== Doctor Hero ===== */
      .doc-hero {
        position: relative;
        background: linear-gradient(180deg, var(--sky-pale) 0%, #ffffff 100%);
        padding: 80px 0 60px;
        overflow: hidden;
      }
      .doc-hero::before {
        content: "";
        position: absolute;
        top: -120px;
        right: -160px;
        width: 480px;
        height: 480px;
        border-radius: 50%;
        background: radial-gradient(
          circle,
          rgba(70, 183, 232, 0.2),
          transparent 70%
        );
      }
      .doc-hero-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 56px;
        align-items: center;
        position: relative;
        z-index: 2;
      }
      .doc-hero-copy h1 {
        font-size: 48px;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }
      .doc-hero-copy .doc-role {
        color: var(--sky);
        font-weight: 700;
        font-size: 18px;
        margin-bottom: 18px;
      }
      .doc-hero-copy p {
        font-size: 17px;
        color: var(--ink-soft);
        max-width: 520px;
        margin-bottom: 28px;
      }
      .doc-hero-cta-row {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 32px;
      }
      .doc-trust-row {
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
      }
      .trust-item {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .trust-num {
        font-family: "Sora", sans-serif;
        font-weight: 800;
        font-size: 22px;
        color: var(--navy);
      }
      .trust-label {
        font-size: 12.5px;
        color: var(--ink-soft);
        font-weight: 600;
        max-width: 100px;
        line-height: 1.3;
      }

      .doc-hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .doc-hero-blob {
        position: absolute;
        width: 400px;
        height: 400px;
        background: linear-gradient(160deg, var(--sky), var(--navy));
        border-radius: 44% 56% 60% 40% / 48% 42% 58% 52%;
        opacity: 0.14;
        animation: blobmove 9s ease-in-out infinite;
      }
      @keyframes blobmove {
        0%,
        100% {
          border-radius: 44% 56% 60% 40% / 48% 42% 58% 52%;
        }
        50% {
          border-radius: 58% 42% 40% 60% / 40% 58% 42% 60%;
        }
      }
      .doc-photo-card {
        position: relative;
        width: 360px;
        animation: floaty 5s ease-in-out infinite;
      }
      @keyframes floaty {
        0%,
        100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(-16px);
        }
      }
      .doc-photo-frame {
        width: 100%;
        aspect-ratio: 4/5;
        border-radius: 28px;
        background: linear-gradient(160deg, var(--navy), var(--sky));
        padding: 6px;
        box-shadow: var(--shadow-lg);
      }
      .doc-photo-inner {
        width: 100%;
        height: 100%;
        border-radius: 24px;
        background: var(--sky-light);
        overflow: hidden;
      }
      .doc-photo-inner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .float-badge {
        position: absolute;
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--shadow-md);
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 12.5px;
        font-weight: 700;
        color: var(--navy);
        animation: floaty 4.5s ease-in-out infinite;
      }
      .badge-1 {
        top: 6%;
        left: -14%;
        animation-delay: 0.4s;
      }
      .badge-2 {
        bottom: 10%;
        right: -16%;
        animation-delay: 0.9s;
      }
      .badge-icon {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        background: var(--sky-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
      }
      .badge-1 .badge-icon {
        background: linear-gradient(135deg, var(--mint), #5adfcb);
        color: #fff;
      }
      .badge-2 .badge-icon {
        background: linear-gradient(135deg, var(--sky), var(--navy));
        color: #fff;
      }

      .curve-divider {
        display: block;
        width: 100%;
        line-height: 0;
      }
      .curve-divider svg {
        width: 100%;
        height: 60px;
        display: block;
      }

      /* ===== Section shared ===== */
      section {
        padding: 88px 0;
      }
      .section-head {
        max-width: 640px;
        margin-bottom: 52px;
      }
      .section-head h2 {
        font-size: 34px;
        font-weight: 800;
        letter-spacing: -0.01em;
        margin-bottom: 14px;
      }
      .section-head p {
        color: var(--ink-soft);
        font-size: 16px;
      }
      .section-alt {
        background: var(--sky-pale);
      }

      /* ===== About Doctor ===== */
      .about-doc-grid {
        display: grid;
        grid-template-columns: 0.95fr 1.05fr;
        gap: 56px;
        align-items: center;
      }
      .about-doc-visual {
        position: relative;
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--shadow-md);
      }
