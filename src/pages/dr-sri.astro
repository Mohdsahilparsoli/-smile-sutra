      .about-doc-point {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        padding: 16px 18px;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.25s ease,
