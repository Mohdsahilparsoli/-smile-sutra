      /* ===== Qualifications ===== */
      .qual-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }
      .qual-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 28px 24px;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
        position: relative;
        overflow: hidden;
      }
      .qual-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--sky), var(--mint));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
      }
      .qual-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-lg);
      }
      .qual-card:hover::before {
        transform: scaleX(1);
      }
      .qual-icon {
        width: 54px;
        height: 54px;
        border-radius: 15px;
        background: var(--sky-light);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--navy);
        margin-bottom: 18px;
      }
      .qual-card h3 {
        font-size: 18px;
        margin-bottom: 8px;
      }
      .qual-card p {
        font-size: 14px;
        color: var(--ink-soft);
        margin-bottom: 12px;
      }
      .qual-card .qual-year {
        font-size: 12.5px;
        font-weight: 700;
        color: var(--mint);
        letter-spacing: 0.04em;
      }

      /* ===== Specializations ===== */
      .spec-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
      }
      .spec-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 26px 20px;
        text-align: center;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease,
          border-color 0.3s ease;
      }
      .spec-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-md);
        border-color: var(--sky);
      }
      .spec-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--sky-light), #fff);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        color: var(--navy);
        border: 2px solid var(--line);
        transition: border-color 0.3s ease;
      }
      .spec-card:hover .spec-icon {
        border-color: var(--sky);
      }
      .spec-card h4 {
        font-size: 15px;
        margin-bottom: 6px;
      }
      .spec-card p {
        font-size: 12.5px;
        color: var(--ink-soft);
      }

      /* ===== Awards ===== */
      .awards-wrap {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
      }
      .awards-visual {
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--shadow-md);
      }
      .awards-visual img {
        width: 100%;
        height: auto;
        display: block;
      }
      .awards-list {
        display: grid;
        gap: 16px;
      }
      .award-item {
        display: flex;
        gap: 16px;
        align-items: flex-start;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        padding: 18px;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }
      .award-item:hover {
        transform: translateX(6px);
        box-shadow: var(--shadow-md);
      }
      .award-icon {
        width: 44px;
        height: 44px;
        flex-shrink: 0;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--sky), var(--navy));
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
      }
      .award-item h4 {
        font-size: 15px;
        margin-bottom: 3px;
      }
      .award-item p {
        font-size: 13px;
        color: var(--ink-soft);
        margin: 0;
      }
      .award-item .award-year {
        font-size: 11.5px;
        font-weight: 700;
        color: var(--mint);
        letter-spacing: 0.04em;
      }

      /* ===== Testimonials ===== */
      .testi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }
      .testi-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 26px;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }
      .testi-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-md);
      }
      .testi-stars {
        color: #f4b400;
        font-size: 14px;
        margin-bottom: 12px;
        display: flex;
        gap: 2px;
      }
      .testi-card p.quote {
        font-size: 14.5px;
        color: var(--ink);
        margin-bottom: 18px;
      }
      .testi-person {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .testi-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--sky), var(--navy));
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 15px;
        overflow: hidden;
      }
      .testi-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .testi-person b {
        display: block;
        font-size: 14px;
        color: var(--navy);
      }
      .testi-person span {
        font-size: 12px;
        color: var(--ink-soft);
      }

      /* ===== CTA / Booking ===== */
      .cta-section {
        background: linear-gradient(135deg, var(--navy), var(--navy-deep));
        border-radius: 28px;
        padding: 60px 52px;
        color: #fff;
        position: relative;
        overflow: hidden;
      }
      .cta-section::after {
        content: "";
        position: absolute;
        bottom: -100px;
        right: -100px;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        background: radial-gradient(
          circle,
          rgba(70, 183, 232, 0.25),
          transparent 70%
        );
      }
      .cta-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 40px;
        align-items: center;
        position: relative;
        z-index: 2;
      }
      .cta-copy .eyebrow {
        background: rgba(255, 255, 255, 0.12);
        color: #8fe0d3;
      }
      .cta-copy .eyebrow::before {
        background: #8fe0d3;
      }
      .cta-copy h2 {
        color: #fff;
        font-size: 32px;
        margin-bottom: 14px;
      }
      .cta-copy p {
        color: rgba(255, 255, 255, 0.82);
        font-size: 15.5px;
        margin-bottom: 26px;
        max-width: 520px;
      }
      .cta-actions {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }
      .cta-actions .btn-primary {
        background: #fff;
        color: var(--navy);
      }
      .cta-actions .btn-primary:hover {
        background: var(--sky-light);
      }
      .cta-actions .btn-ghost {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.2);
      }
      .cta-actions .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.2);
      }
      .cta-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }
      .cta-stat {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 14px;
        padding: 20px;
        text-align: center;
      }
      .cta-stat b {
        display: block;
        font-family: "Sora", sans-serif;
        font-size: 26px;
        color: #fff;
      }
      .cta-stat span {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.75);
      }

      
      /* ===== Responsive ===== */
      @media (max-width: 980px) {
        .doc-hero-grid,
        .about-doc-grid,
        .awards-wrap,
        .cta-grid {
          grid-template-columns: 1fr;
        }
        .qual-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .spec-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .testi-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .footer-grid {
          grid-template-columns: 1fr 1fr;
        }
        .doc-hero-copy h1 {
          font-size: 38px;
        }
        .cta-section {
          padding: 40px 28px;
        }
      }

      @media (max-width: 720px) {
        nav,
        .call-chip {
          display: none;
        }
        .hamburger {
          display: flex;
        }
        .btn-primary.nav-book {
          display: none;
        }
        section {
          padding: 64px 0;
        }
        .doc-hero {
          padding: 44px 0 30px;
        }
        .doc-hero-copy h1 {
          font-size: 32px;
        }
        .qual-grid {
          grid-template-columns: 1fr;
        }
        .spec-grid {
          grid-template-columns: 1fr 1fr;
        }
        .testi-grid {
          grid-template-columns: 1fr;
        }
        .footer-grid {
          grid-template-columns: 1fr;
        }
        .doc-photo-card {
          width: 270px;
        }
        .float-badge {
          font-size: 11px;
          padding: 8px 10px;
        }
        .badge-1 {
          left: -8%;
        }
        .badge-2 {
          right: -8%;
        }
        .doc-trust-row {
          gap: 18px;
        }
        .section-head h2 {
          font-size: 27px;
        }
        .cta-stats {
          grid-template-columns: 1fr 1fr;
        }
      }


    </style>

    <script is:inline>
      const hamburgerBtn = document.getElementById("hamburgerBtn");
      const closeDrawer = document.getElementById("closeDrawer");
      const mobileNav = document.getElementById("mobileNav");
      const navOverlay = document.getElementById("navOverlay");

      function openDrawer() {
        mobileNav.classList.add("open");
        navOverlay.classList.add("open");
      }
      function closeDrawerFn() {
        mobileNav.classList.remove("open");
        navOverlay.classList.remove("open");
      }
      hamburgerBtn.addEventListener("click", openDrawer);
      closeDrawer.addEventListener("click", closeDrawerFn);
      navOverlay.addEventListener("click", closeDrawerFn);
      mobileNav
        .querySelectorAll("a")
        .forEach((a) => a.addEventListener("click", closeDrawerFn));

      const revealEls = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in-view");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );
      revealEls.forEach((el) => io.observe(el));

      const headerEl = document.querySelector("header");
      window.addEventListener("scroll", () => {
        if (window.scrollY > 10) {
          headerEl.style.boxShadow = "0 4px 20px rgba(11,59,92,0.08)";
        } else {
          headerEl.style.boxShadow = "none";
        }
      });
    </script>
</Layout>
