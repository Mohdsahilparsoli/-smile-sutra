---
import AboutHeroImage from "../assets/blog-placeholder-about.jpg";
import Layout from "../layouts/BlogPost.astro";
---

<Layout
  title="Patient Reviews | Smile Sutra Dental Clinic | 4.9★ Rated Dentist in Delhi NCR"
  description="Read genuine patient reviews for Smile Sutra Dental Clinic. Discover why families across Delhi, Noida, Gurgaon, and Ghaziabad trust us for dental implants, root canal treatment, cosmetic dentistry, and complete dental care."
  pubDate={new Date("August 08 2021")}
  heroImage={AboutHeroImage}
>
  <!-- ===== REVIEWS HERO ===== -->
  <section class="reviews-hero" id="top">
    <div class="container reviews-hero-grid">
      <div class="reviews-hero-copy reveal in-view">
        <div class="eyebrow">Patient Reviews</div>
        <h1>Real stories from <span>real smiles</span> across Delhi NCR</h1>
        <p>
          Over 800 verified patient reviews and counting. Read honest
          experiences from families across Delhi, Noida, Gurgaon, and Ghaziabad
          who trusted Smile Sutra with their dental care.
        </p>
        <div style="display:flex; gap:14px; flex-wrap:wrap;">
          <a href="#all-reviews" class="btn btn-primary">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
