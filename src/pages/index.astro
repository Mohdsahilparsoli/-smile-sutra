---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
  title="Best Dentist in Delhi NCR | Root Canal, Braces & Dental Implants | Dr. Sri"
  description="Looking for the best dentist in Delhi NCR? Dr. Sri offers painless root canal treatment, invisible braces, dental implants, smile makeovers, and complete family dental care with 10+ years of experience and 5000+ happy patients."
/>
    <style>
      /* ===== Hero ===== */
      .hero {
        position: relative;
        background: linear-gradient(180deg, var(--sky-pale) 0%, #ffffff 100%);
        padding: 72px 0 40px;
        overflow: hidden;
      }
      .hero::before {
        content: "";
        position: absolute;
        top: -120px;
        right: -160px;
        width: 480px;
        height: 480px;
        border-radius: 50%;
        background: radial-gradient(
          circle,
          rgba(70, 183, 232, 0.2),
          transparent 70%
        );
      }
      .hero-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 48px;
        align-items: center;
        position: relative;
        z-index: 2;
      }
      .hero-copy h1 {
        font-size: 46px;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 20px;
      }
      .hero-copy h1 span {
        color: var(--sky);
        position: relative;
        white-space: nowrap;
      }
      .hero-copy p {
        font-size: 17px;
        color: var(--ink-soft);
        max-width: 520px;
        margin-bottom: 28px;
      }
      .hero-cta-row {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 36px;
      }
      .trust-row {
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
      }
      .trust-item {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .trust-num {
        font-family: "Sora", sans-serif;
        font-weight: 800;
        font-size: 22px;
        color: var(--navy);
      }
      .trust-label {
        font-size: 12.5px;
        color: var(--ink-soft);
        font-weight: 600;
        max-width: 100px;
        line-height: 1.3;
      }

      .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .hero-blob {
        position: absolute;
        width: 390px;
        height: 390px;
        background: linear-gradient(160deg, var(--sky), var(--navy));
        border-radius: 44% 56% 60% 40% / 48% 42% 58% 52%;
        opacity: 0.14;
        animation: blobmove 9s ease-in-out infinite;
      }
      @keyframes blobmove {
        0%,
        100% {
          border-radius: 44% 56% 60% 40% / 48% 42% 58% 52%;
        }
        50% {
          border-radius: 58% 42% 40% 60% / 40% 58% 42% 60%;
        }
      }
      .doctor-card {
        position: relative;
        width: 340px;
        animation: floaty 5s ease-in-out infinite;
      }
      @keyframes floaty {
        0%,
        100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(-16px);
        }
      }
      .doctor-photo-frame {
        width: 100%;
        aspect-ratio: 4/5;
        border-radius: 28px;
        background: linear-gradient(160deg, var(--navy), var(--sky));
        padding: 6px;
        box-shadow: var(--shadow-lg);
      }
      .doctor-photo-inner {
        width: 100%;
        height: 100%;
        border-radius: 24px;
        background: var(--sky-light);
        display: flex;
        align-items: flex-end;
        justify-content: center;
        overflow: hidden;
        position: relative;
      }
      .doctor-silhouette {
        height: 100%;
      }
      .float-badge {
        position: absolute;
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--shadow-md);
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 12.5px;
        font-weight: 700;
        color: var(--navy);
        animation: floaty 4.5s ease-in-out infinite;
      }
      .badge-1 {
        top: 6%;
        left: -14%;
        animation-delay: 0.4s;
      }
      .badge-2 {
        bottom: 10%;
        right: -16%;
        animation-delay: 0.9s;
      }
      .badge-icon {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        background: var(--sky-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
      }
      .badge-1 .badge-icon {
        background: linear-gradient(135deg, var(--mint), #5adfcb);
        color: #fff;
      }
      .badge-2 .badge-icon {
        background: linear-gradient(135deg, var(--sky), var(--navy));
        color: #fff;
      }

      /* smile-curve divider */
      .curve-divider {
        display: block;
        width: 100%;
        line-height: 0;
      }
      .curve-divider svg {
        width: 100%;
        height: 60px;
        display: block;
      }

      /* ===== Section shared ===== */
      section {
        padding: 88px 0;
      }
      .section-head {
        max-width: 640px;
        margin-bottom: 52px;
      }
      .section-head h2 {
        font-size: 34px;
        font-weight: 800;
        letter-spacing: -0.01em;
        margin-bottom: 14px;
      }
      .section-head p {
        color: var(--ink-soft);
        font-size: 16px;
      }
      .section-alt {
        background: var(--sky-pale);
      }

      /* ===== About ===== */
      .about-grid {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 56px;
        align-items: center;
      }
      .about-visual {
        position: relative;
        border-radius: var(--radius);
        background: linear-gradient(160deg, var(--navy), var(--sky));
        padding: 32px;
        color: #fff;
        box-shadow: var(--shadow-md);
      }
      .about-visual h3 {
        color: #fff;
        font-size: 22px;
        margin-bottom: 10px;
      }
      .about-visual p {
        color: rgba(255, 255, 255, 0.85);
        font-size: 14.5px;
        margin-bottom: 22px;
      }
      .location-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
      .location-tags span {
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 8px 14px;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 600;
      }
      .about-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        margin-top: 24px;
      }
      .about-stat {
        background: rgba(255, 255, 255, 0.12);
        border-radius: var(--radius-sm);
        padding: 16px;
      }
      .about-stat b {
        display: block;
        font-family: "Sora", sans-serif;
        font-size: 22px;
      }
      .about-stat span {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.8);
      }

      .about-body p {
        color: var(--ink-soft);
        margin-bottom: 16px;
        font-size: 15.5px;
      }
      .about-points {
        display: grid;
        gap: 14px;
        margin-top: 22px;
      }
      .about-point {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        padding: 16px 18px;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }
      .about-point:hover {
        transform: translateX(6px);
        box-shadow: var(--shadow-md);
      }
      .about-point-icon {
        width: 38px;
        height: 38px;
        flex-shrink: 0;
        border-radius: 10px;
        background: var(--sky-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
      }
      .about-point h4 {
        font-size: 15.5px;
        margin-bottom: 3px;
      }
      .about-point p {
        font-size: 13.5px;
        color: var(--ink-soft);
        margin: 0;
      }

      /* ===== Services ===== */
      .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }
      .service-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 28px 24px;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease,
          border-color 0.3s ease;
        position: relative;
        overflow: hidden;
      }
      .service-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--sky), var(--mint));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
      }
      .service-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-lg);
        border-color: transparent;
      }
      .service-card:hover::before {
        transform: scaleX(1);
      }
      .service-icon {
        width: 54px;
        height: 54px;
        border-radius: 15px;
        background: var(--sky-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        margin-bottom: 18px;
      }
      .service-card h3 {
        font-size: 18px;
        margin-bottom: 8px;
      }
      .service-card p {
        font-size: 14px;
        color: var(--ink-soft);
        margin-bottom: 16px;
      }
      .service-price {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 14px;
        border-top: 1px dashed var(--line);
      }
      .service-price b {
        color: var(--navy);
        font-size: 15px;
      }
      .service-price a {
        font-size: 13px;
        font-weight: 700;
        color: var(--sky);
      }
      .service-price a:hover {
        color: var(--navy);
      }

      /* ===== Specialist ===== */
      .specialist {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 52px;
        align-items: center;
        background: linear-gradient(135deg, var(--navy), var(--navy-deep));
        border-radius: 28px;
        padding: 52px;
        color: #fff;
        position: relative;
        overflow: hidden;
      }
      .specialist::after {
        content: "";
        position: absolute;
        bottom: -100px;
        left: -100px;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        background: radial-gradient(
          circle,
          rgba(70, 183, 232, 0.25),
          transparent 70%
        );
      }
      .specialist-photo {
        position: relative;
        z-index: 2;
      }
      .specialist-photo-frame {
        width: 100%;
        aspect-ratio: 1/1.05;
        border-radius: 22px;
        background: linear-gradient(160deg, var(--sky), #fff2);
        padding: 5px;
      }
      .specialist-photo-inner {
        width: 100%;
        height: 100%;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: flex-end;
        justify-content: center;
        overflow: hidden;
      }
      .specialist-photo-inner img.doctor-silhouette {
        max-width: 100%;
        height: 100%;
        object-fit: cover;
        width: 100%;
      }
      .specialist-info {
        position: relative;
        z-index: 2;
      }
      .specialist-info .eyebrow {
        background: rgba(255, 255, 255, 0.12);
        color: #8fe0d3;
      }
      .specialist-info .eyebrow::before {
        background: #8fe0d3;
      }
      .specialist-info h2 {
        color: #fff;
        font-size: 30px;
        margin-bottom: 6px;
      }
      .specialist-role {
        color: var(--sky);
        font-weight: 700;
        font-size: 14.5px;
        margin-bottom: 18px;
      }
      .specialist-info p.desc {
        color: rgba(255, 255, 255, 0.82);
        font-size: 15px;
        margin-bottom: 24px;
        max-width: 520px;
      }
      .cred-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 26px;
      }
      .cred-item {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 14px;
        padding: 16px;
        text-align: center;
      }
      .cred-item b {
        display: block;
        font-family: "Sora", sans-serif;
        font-size: 21px;
        color: #fff;
      }
      .cred-item span {
        font-size: 11.5px;
        color: rgba(255, 255, 255, 0.75);
      }
      .cred-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
      }
      .cred-tags span {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 7px 13px;
        border-radius: 100px;
        font-size: 12.5px;
      }

      /* ===== Appointment form ===== */
      .appt-wrap {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 44px;
        align-items: flex-start;
      }
      .appt-side h2 {
        font-size: 32px;
        margin-bottom: 16px;
      }
      .appt-side p {
        color: var(--ink-soft);
        font-size: 15.5px;
        margin-bottom: 26px;
      }
      .appt-perks {
        display: grid;
        gap: 16px;
      }
      .appt-perk {
        display: flex;
        gap: 12px;
        align-items: flex-start;
      }
      .appt-perk .badge-icon {
        background: var(--sky-light);
      }
      .appt-perk h4 {
        font-size: 14.5px;
        margin-bottom: 2px;
      }
      .appt-perk p {
        font-size: 13px;
        margin: 0;
        color: var(--ink-soft);
      }

      .appt-form {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 34px;
        box-shadow: var(--shadow-md);
      }
      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 16px;
      }
      .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .form-group.full {
        grid-column: 1/-1;
      }
      .form-group label {
        font-size: 13px;
        font-weight: 700;
        color: var(--navy);
      }
      .form-group input,
      .form-group select {
        border: 1.5px solid var(--line);
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 14.5px;
        font-family: inherit;
        color: var(--ink);
        background: var(--sky-pale);
        transition:
          border-color 0.2s ease,
          background 0.2s ease;
      }
      .form-group input:focus,
      .form-group select:focus {
        outline: none;
        border-color: var(--sky);
        background: #fff;
      }
      .phone-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--line);
        border-radius: 12px;
        background: var(--sky-pale);
        overflow: hidden;
        transition:
          border-color 0.2s ease,
          background 0.2s ease;
      }
      .phone-wrap:focus-within {
        border-color: var(--sky);
        background: #fff;
      }
      .phone-wrap span {
        padding: 12px 12px;
        font-weight: 700;
        color: var(--navy);
        border-right: 1.5px solid var(--line);
        font-size: 14.5px;
      }
      .phone-wrap input {
        border: none;
        background: transparent;
        flex: 1;
        padding: 12px 14px;
        font-size: 14.5px;
        font-family: inherit;
      }
      .phone-wrap input:focus {
        outline: none;
      }
      .form-note {
        font-size: 12px;
        color: var(--ink-soft);
        margin-top: 14px;
        text-align: center;
      }
      #form-success {
        display: none;
        text-align: center;
        padding: 40px 10px;
      }
      #form-success .badge-icon {
        width: 56px;
        height: 56px;
        font-size: 28px;
        margin: 0 auto 16px;
        background: var(--mint);
        color: #fff;
        border-radius: 16px;
      }
      #form-success h3 {
        margin-bottom: 8px;
      }
      #form-success p {
        color: var(--ink-soft);
        font-size: 14.5px;
      }

      /* ===== Testimonials ===== */
      .testi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }
      .testi-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 26px;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }
      .testi-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-md);
      }
      .testi-stars {
        color: #f4b400;
        font-size: 14px;
        margin-bottom: 12px;
        letter-spacing: 2px;
      }
      .testi-card p.quote {
        font-size: 14.5px;
        color: var(--ink);
        margin-bottom: 18px;
      }
      .testi-person {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .testi-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--sky), var(--navy));
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 15px;
      }
      .testi-person b {
        display: block;
        font-size: 14px;
        color: var(--navy);
      }
      .testi-person span {
        font-size: 12px;
        color: var(--ink-soft);
      }

      /* ===== Contact ===== */
      .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
      }
      .contact-cards {
        display: grid;
        gap: 16px;
      }
      .contact-card {
        display: flex;
        gap: 16px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        padding: 18px;
        box-shadow: var(--shadow-sm);
        align-items: flex-start;
      }
      .contact-card .badge-icon {
        width: 44px;
        height: 44px;
        font-size: 20px;
        border-radius: 12px;
      }
      .contact-card h4 {
        font-size: 15px;
        margin-bottom: 4px;
      }
      .contact-card p {
        font-size: 13.5px;
        color: var(--ink-soft);
        margin: 0;
      }
      .contact-card a {
        color: var(--sky);
        font-weight: 700;
      }
      .map-frame {
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--line);
        height: 100%;
        min-height: 360px;
      }
      .map-frame iframe {
        width: 100%;
        height: 100%;
        min-height: 360px;
        border: 0;
        display: block;
      }

      /* ===== Responsive ===== */
      @media (max-width: 980px) {
        .hero-grid,
        .about-grid,
        .specialist,
        .appt-wrap,
        .contact-grid {
          grid-template-columns: 1fr;
        }
        .specialist {
          padding: 36px 26px;
        }
        .specialist-photo {
          max-width: 320px;
          margin: 0 auto;
        }
        .services-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .testi-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .footer-grid {
          grid-template-columns: 1fr 1fr;
        }
        .hero-copy h1 {
          font-size: 38px;
        }
      }

      @media (max-width: 720px) {
        nav,
        .call-chip {
          display: none;
        }
        .hamburger {
          display: flex;
        }
        .btn-primary.nav-book {
          display: none;
        }
        section {
          padding: 64px 0;
        }
        .hero {
          padding: 44px 0 30px;
        }
        .hero-copy h1 {
          font-size: 32px;
        }
        .services-grid {
          grid-template-columns: 1fr;
        }
        .testi-grid {
          grid-template-columns: 1fr;
        }
        .form-row {
          grid-template-columns: 1fr;
        }
        .footer-grid {
          grid-template-columns: 1fr;
        }
        .cred-grid {
          grid-template-columns: repeat(3, 1fr);
        }
        .doctor-card {
          width: 270px;
        }
        .float-badge {
          font-size: 11px;
          padding: 8px 10px;
        }
        .badge-1 {
          left: -8%;
        }
        .badge-2 {
          right: -8%;
        }
        .trust-row {
          gap: 18px;
        }
        .section-head h2 {
          font-size: 27px;
        }
      }

      /* Mobile nav drawer */
      .mobile-nav {
        position: fixed;
        top: 0;
        right: 0;
        height: 100vh;
        width: 78%;
        max-width: 320px;
        background: #fff;
        box-shadow: -10px 0 40px rgba(11, 59, 92, 0.2);
        z-index: 1100;
        padding: 26px 24px;
        transform: translateX(100%);
        transition: transform 0.35s ease;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .mobile-nav.open {
        transform: translateX(0);
      }
      .mobile-nav a {
        padding: 14px 6px;
        font-weight: 700;
        color: var(--navy);
        border-bottom: 1px solid var(--line);
        font-size: 15px;
      }
      .mobile-nav .btn {
        margin-top: 16px;
      }
      .nav-overlay {
        position: fixed;
        inset: 0;
        background: rgba(11, 59, 92, 0.35);
        z-index: 1050;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }
      .nav-overlay.open {
        opacity: 1;
        pointer-events: auto;
      }
      .close-drawer {
        align-self: flex-end;
        background: var(--sky-light);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        font-size: 16px;
        margin-bottom: 10px;
        color: var(--navy);
      }
