---
import HeaderLink from "./HeaderLink.astro";
---


<!-- ===== HEADER ===== -->
<header>
  <div class="nav-wrap">
    <a href="/" class="logo">
      <span class="logo-mark">🦷</span>
      <span>Smile Sutra<small>Dental &amp; Implant Clinic</small></span>
    </a>
    <nav>
      <ul>
        <li><HeaderLink href="/about">About</HeaderLink></li>
        <li><HeaderLink href="/services">Services</HeaderLink></li>
        <li><HeaderLink href="/dr-sri">Dr. Sri</HeaderLink></li>
        <li><HeaderLink href="/reviews">Reviews</HeaderLink></li>
        <li><HeaderLink href="/contact">Contact</HeaderLink></li>
      </ul>
    </nav>
    <div class="nav-cta">
      <span class="call-chip">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M22 16.92v3a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 3.09 5.18 2 2 0 0 1 5.08 3h3a2 2 0 0 1 2 1.72l.36 2.45a2 2 0 0 1-.57 1.74L8.09 10.91a16 16 0 0 0 5 5l2-2a2 2 0 0 1 1.74-.57l2.45.36A2 2 0 0 1 22 16.92z"
          ></path></svg
        > +91 98100 22334</span
      >
      <HeaderLink href="/#appointment" class="btn btn-primary nav-book"
        >Book Appointment</HeaderLink
      >
      <button class="hamburger" id="hamburgerBtn" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="nav-overlay" id="navOverlay"></div>
<div class="mobile-nav" id="mobileNav">
  <button class="close-drawer" id="closeDrawer">✕</button>
  <HeaderLink href="/about">About</HeaderLink>
  <HeaderLink href="/services">Services</HeaderLink>
  <HeaderLink href="/dr-sri">Dr. Sri</HeaderLink>
  <HeaderLink href="/reviews">Reviews</HeaderLink>
  <HeaderLink href="/contact">Contact</HeaderLink>
  <HeaderLink href="/#appointment" class="btn btn-primary btn-block">Book Appointment</HeaderLink>
</div>
