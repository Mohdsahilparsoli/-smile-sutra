<script is:inline>
  // Mobile nav drawer
  const hamburgerBtn = document.getElementById('hamburgerBtn');
  const closeDrawer = document.getElementById('closeDrawer');
  const mobileNav = document.getElementById('mobileNav');
  const navOverlay = document.getElementById('navOverlay');

  function openDrawer(){
    mobileNav.classList.add('open');
    navOverlay.classList.add('open');
  }
  function closeDrawerFn(){
    mobileNav.classList.remove('open');
    navOverlay.classList.remove('open');
  }
  hamburgerBtn.addEventListener('click', openDrawer);
  closeDrawer.addEventListener('click', closeDrawerFn);
  navOverlay.addEventListener('click', closeDrawerFn);
  mobileNav.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawerFn));

  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if(entry.isIntersecting){
        entry.target.classList.add('in-view');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  revealEls.forEach(el => io.observe(el));

  // Appointment form submit
  const apptForm = document.getElementById('apptForm');
  apptForm.addEventListener('submit', function(e){
    e.preventDefault();
    document.getElementById('form-fields').style.display = 'none';
    document.getElementById('form-success').style.display = 'block';
  });

  // Set min date to today for the date field
  const dateInput = document.getElementById('fdate');
  if(dateInput){
    const today = new Date().toISOString().split('T')[0];
    dateInput.setAttribute('min', today);
  }

  // Header shadow on scroll
  const headerEl = document.querySelector('header');
  window.addEventListener('scroll', () => {
    if(window.scrollY > 10){
      headerEl.style.boxShadow = '0 4px 20px rgba(11,59,92,0.08)';
    } else {
      headerEl.style.boxShadow = 'none';
    }
  });
</script>